# ============================================================
# Wamio — copiá este archivo a .env y completá TODAS las claves.
# Generá valores únicos y largos:  openssl rand -hex 32
# No reutilices contraseñas entre servicios.
#
# ⚠️  IMPORTANTE — contraseñas SIN caracteres especiales de URL.
# POSTGRES_PASSWORD y REDIS_PASSWORD terminan dentro de cadenas de
# conexión tipo  postgresql://user:PASS@host  y  redis://:PASS@host.
# Si la contraseña tiene  # @ : / ? & % + espacios  rompe el parseo de
# la URL y los servicios NO conectan (ej. Evolution tira "invalid port
# number in database URL" y Directus "connect ECONNREFUSED 127.0.0.1").
# Usá SOLO letras y números.  `openssl rand -hex 32` genera hex seguro.
# ============================================================

# --- Imágenes (construidas por CI en GHCR) ---
# "latest" sigue la rama main; también podés fijar un SHA de commit
# (ej: WAMIO_IMAGE_TAG=a1b2c3d) para deploys reproducibles.
WAMIO_IMAGE_TAG=latest

# --- Dominio público (único punto de entrada) ---
# Todo entra por este dominio a través del router (contenedor "landing"):
#   /        -> landing        (marketing)
#   /admin   -> Directus       (panel del comercio)
#   /n8n     -> n8n            (automatizaciones)
#   /api     -> Evolution API   (REST del gateway de WhatsApp)
# En desarrollo local usá http://localhost:8060
WAMIO_PUBLIC_URL=https://wamio.pymesenlinea.com.ar

# --- Postgres (compartido por todos los servicios) ---
POSTGRES_USER=wamio_admin
POSTGRES_PASSWORD=cambiar_esta_clave

# --- Redis ---
REDIS_PASSWORD=cambiar_esta_clave

# --- Evolution API (gateway de WhatsApp) ---
EVOLUTION_API_KEY=cambiar_esta_clave

# --- n8n (orquestador) ---
# Solo el host y el protocolo del dominio público (sin https:// ni ruta).
# El resto de los links (editor, webhooks bajo /n8n/) se derivan de
# WAMIO_PUBLIC_URL de arriba.
# En desarrollo local: N8N_HOST=localhost, N8N_PROTOCOL=http
N8N_HOST=wamio.pymesenlinea.com.ar
N8N_PROTOCOL=https

# --- Directus (panel admin) ---
DIRECTUS_SECRET=cambiar_esta_clave
DIRECTUS_ADMIN_EMAIL=admin@example.com
DIRECTUS_ADMIN_PASSWORD=cambiar_esta_clave

# --- Mercado Pago ---
MP_ACCESS_TOKEN=cambiar_esta_clave

# --- Chatwoot (opcional, profile "chatwoot") ---
CHATWOOT_SECRET_KEY_BASE=cambiar_esta_clave
CHATWOOT_FRONTEND_URL=http://localhost:3000
